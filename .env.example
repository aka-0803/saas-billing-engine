# Database
# Local dev (no Docker):      mysql://root:password@localhost:3306/billing_db
# Local Docker testing:        mysql://root:password@host.docker.internal:3306/billing_db
# EC2 production:              mysql://admin:password@your-rds-endpoint.rds.amazonaws.com:3306/billing_db
DATABASE_URL=mysql://user:password@host:3306/billing_db

# Auth — must be 32+ characters in production
JWT_SECRET=your-super-secret-key

# Redis — REDIS_HOST is overridden to 'redis' by docker-compose automatically
REDIS_HOST=localhost
REDIS_PORT=6379

# App
PORT=3000

# AWS S3
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_REGION=your-region
S3_BUCKET_NAME=your-bucket-name
